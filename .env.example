# PrizePicks EV Bot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.

# ─────────────────────────────────────────────
# ODDS API
# Get a free key at https://the-odds-api.com
# Free tier: 500 requests/month. Paid tier needed for prod.
# ─────────────────────────────────────────────
ODDS_API_KEY=your_odds_api_key_here

# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ppev:password@localhost:5432/prizepicks_ev_bot

# ─────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────
# DISCORD ALERTS (optional for now)
# Server Settings → Integrations → Webhooks → New Webhook → Copy URL
# ─────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_here

# ─────────────────────────────────────────────
# APP SETTINGS
# ─────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
BANKROLL=1000.00
